{
  "chat": {
    "enableLocalChat": true,
    "enableGlobalChat": true,
    "localChatRadius": 100,
    "globalChatSymbol": "!",
    "globalChatFormat": "&6[G] &f{player}: &7{message}",
    "localChatFormat": "&7[Локальный] &f{player}: &7{message}"
  },
  "antiSpam": {
    "enableAntiSpam": true,
    "enableAntiFlood": true,
    "messageCooldown": 3,
    "maxRepeatedMessages": 3,
    "floodThreshold": 5,
    "floodTimeWindow": 10,
    "cooldownMessage": "&cПодождите перед отправкой следующего сообщения.",
    "repeatMessage": "&cНе повторяйте одно и то же сообщение.",
    "floodMessage": "&cВы отправляете сообщения слишком быстро."
  },
  "notifications": {
    "enableJoinMessages": true,
    "enableQuitMessages": true,
    "joinMessage": "&a+ {player} присоединился к серверу",
    "quitMessage": "&c- {player} покинул сервер"
  },
  "timing": {
    "joinMessageDelayTicks": 5,
    "quitMessageDelayTicks": 3,
    "muteCleanupIntervalTicks": 100,
    "ticksPerSecond": 20
  },
  "autoBroadcast": {
    "enableAutoBroadcast": true,
    "broadcastInterval": 300,
    "randomizeMessages": false,
    "showBroadcastPrefix": false,
    "broadcastPrefix": "&d[Автобродкаст] &r",
    "broadcastMessages": [
      "&6&lДобро пожаловать на сервер!",
      "&bОнлайн: &f{online}&b/&f{max_online}",
      "&7Память: &f{memory_used}MB&7/&f{memory_max}MB",
      "&3Uptime: &f{uptime_hours}&3ч &f{uptime_minutes}&3м",
      "&2TPS: &f{tps}"
    ]
  },
  "moderation": {
    "enableModeration": true,
    "saveMuteData": true,
    "defaultMuteReason": "Нарушение правил",
    "staffNotificationPrefix": "&e[Модерация] ",
    "defaultMuteDuration": "1h",
    "notifyStaffOnMute": true,
    "logMuteActions": true
  },
  "permissions": {
    "enablePermissionSystem": true,
    "defaultCanUseGlobalChat": true,
    "defaultCanUseLocalChat": true,
    "enablePermissionCache": true,
    "permissionCacheTimeout": 300
  },
  "commandMessages": {
    "reloadSuccess": "&aКонфиг NextgenChat перезагружен!"
  }
}
